# ============================================================================
# Production Environment Configuration for Zebu
# ============================================================================
# This file contains application secrets and configuration for production deployment.
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.production.example .env
# 2. Edit .env with your actual secrets (generate secure passwords/keys)
# 3. The .env file is gitignored - it won't be committed
#
# GENERATING SECURE VALUES:
#   - Passwords: openssl rand -base64 32
#   - Secret keys: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# DO NOT commit the .env file with real credentials to version control!
#
# NOTE: For Proxmox VM deployment, you also need .env.proxmox
#   - .env = Application secrets (this file)
#   - .env.proxmox = VM infrastructure config (see .env.proxmox.example)

# ============================================================================
# DATABASE CONFIGURATION (Required)
# ============================================================================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=papertrade
POSTGRES_USER=papertrade
# Generate a secure password: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_SECURE_PASSWORD

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# Optional: Set Redis password for additional security
# REDIS_PASSWORD=CHANGE_ME_GENERATE_SECURE_PASSWORD

# ============================================================================
# APPLICATION SECURITY (Required)
# ============================================================================
# Generate a secure secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_SECURE_SECRET_KEY

# Clerk authentication secret (Required in production).
# When APP_ENV=production, the backend now refuses to start auth without
# a real Clerk secret — it will raise RuntimeError on the first request
# rather than silently fall back to the in-memory test adapter. Get it
# from: https://dashboard.clerk.com/last-active?path=api-keys
CLERK_SECRET_KEY=sk_live_YOUR_PRODUCTION_SECRET_HERE

# Admin allowlist (Phase B / Wave 1-A).
# Comma-separated Clerk user IDs (raw strings, e.g. "user_2abc...,user_2def...")
# allowed to call admin endpoints: POST /api/v1/analytics/prices/refresh,
# POST /api/v1/analytics/snapshots/daily, GET /api/v1/debug/*, and the
# admin-only price routes (POST /api/v1/prices/fetch-historical,
# GET /api/v1/prices/debug/cache/*). Empty / unset = nobody is admin.
# Add the operator's Clerk user ID(s) here when provisioning a new env.
ADMIN_USER_IDS=

# ============================================================================
# MARKET DATA API (Required for Phase 2+)
# ============================================================================
# Get your free API key: https://www.alphavantage.co/support/#api-key
# Free tier: 5 API calls/min, 500 calls/day
# Premium tiers: https://www.alphavantage.co/premium/
ALPHA_VANTAGE_API_KEY=your_api_key_here

# Rate limits (adjust based on your API tier)
ALPHA_VANTAGE_RATE_LIMIT_PER_MIN=5
ALPHA_VANTAGE_RATE_LIMIT_PER_DAY=500

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
APP_ENV=production
APP_DEBUG=false
APP_LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Database SQL Echo — MUST be false in production.
# When true, every SQL statement plus bind params is written to the log
# pipeline (sensitive value leakage + measurable per-request latency).
DB_ECHO=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS Configuration (for production with custom domain)
# Comma-separated list of allowed origins for API requests
# Example for custom domain: https://yourdomain.com,https://api.yourdomain.com
# Default (localhost) is fine for local production testing
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# COMPOSITE DATABASE URL
# ============================================================================
# This is automatically constructed from the individual database variables above.

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# Backend API URL for frontend to connect to
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ============================================================================
# SECURITY NOTES
# ============================================================================
# 1. Generate secure passwords/keys using the commands provided above
# 2. Never commit the .env file with real credentials
# 3. Use different secrets for development and production
# 4. Rotate secrets regularly
# 5. Use environment-specific secrets management in cloud deployments (AWS Secrets Manager, etc.)
